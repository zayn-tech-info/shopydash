# Optional: override API URL (used when building with npm run build).
# Set to your backend URL when testing production build locally, e.g.:
# VITE_API_URL=http://localhost:8000
# Leave unset to use default (dev: http://localhost:8000, prod: https://api.shopydash.com)
MODE=production
VITE_API_URL=http://localhost:8000
# VITE_GOOGLE_CLIENT_ID=your-google-client-id
