# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=8000

# Database Configuration
CONNECTION_URI=mongodb://localhost:27017/vendora

# JWT Configuration
# IMPORTANT: Use a strong secret key (at least 32 characters)
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters_required

# Cloudinary Configuration (for image uploads)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARYAPI_KEY=your_cloudinary_api_key
CLOUDINARYAPI_API_SECRET=your_cloudinary_api_secret

# Paystack Payment Gateway Configuration
# Use test key for development, production key for production
PAYSTACK_TEST_SECRET_KEY=sk_test_your_paystack_test_key
# PAYSTACK_SECRET_KEY=sk_live_your_paystack_production_key

# Client URL (for CORS and redirect URLs)
CLIENT_URL=http://localhost:5173
